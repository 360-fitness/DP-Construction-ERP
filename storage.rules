rules_version = '2';

// Paste into Firebase Console > Storage > Rules.
service firebase.storage {
  match /b/{bucket}/o {
    match /company/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // tighten to admin-only once custom claims are set up
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
